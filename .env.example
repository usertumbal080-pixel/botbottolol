# Token Discord Bot (dari Discord Developer Portal)
TOKEN=your_discord_bot_token_here

# URL API yang sudah di-deploy (Railway/Render)
API_URL=https://your-api.railway.app

# API Key (harus sama dengan yang di API server)
API_KEY=rahasia123

# Cooldown per user dalam detik
COOLDOWN=30

# Port untuk Flask keepalive
PORT=10000
